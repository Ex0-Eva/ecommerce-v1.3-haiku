// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]

  orders        Order[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id                   String           @id @default(cuid())
  name                 String
  description          String?
  price                Decimal          @db.Decimal(10, 2)
  stock                Int              @default(0)
  imageUrl             String?          @map("image_url")
  productType          String           @default("physical") @map("product_type") // 'physical', 'digital'
  digitalFileUrl       String?          @map("digital_file_url")
  affiliateUrl         String?          @map("affiliate_url")
  licenseKeyRequired   Boolean          @default(false) @map("license_key_required")
  isActive             Boolean          @default(true) @map("is_active")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  variants             ProductVariant[]
  orderItems           OrderItem[]
  licenseKeys          LicenseKey[]
  liveStreams          LiveStream[]

  @@map("products")
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  label       String
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  sku         String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@map("product_variants")
}

model Order {
  id                String       @id @default(cuid())
  userId            String?      @map("user_id")
  customerName      String?      @map("customer_name")
  customerEmail     String?      @map("customer_email")
  shippingAddress   Json?        @map("shipping_address")
  total             Decimal      @db.Decimal(10, 2)
  status            String       @default("pending") // pending, paid, shipped, delivered, cancelled
  stripeSessionId   String?      @map("stripe_session_id")
  opennodeChargeId  String?      @map("opennode_charge_id")
  lnbitsCheckingId  String?      @map("lnbits_checking_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderItems        OrderItem[]
  licenseKeys       LicenseKey[]

  @@map("orders")
}

model OrderItem {
  id           String          @id @default(cuid())
  orderId      String          @map("order_id")
  productId    String?         @map("product_id")
  productName  String          @map("product_name")
  productPrice Decimal         @db.Decimal(10, 2) @map("product_price")
  quantity     Int
  licenseKey   String?         @map("license_key")
  variantId    String?         @map("variant_id")
  variantLabel String?         @map("variant_label")
  createdAt    DateTime        @default(now()) @map("created_at")

  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model LicenseKey {
  id         String   @id @default(cuid())
  productId  String?  @map("product_id")
  keyValue   String   @unique @map("key_value")
  isUsed     Boolean  @default(false) @map("is_used")
  orderId    String?  @map("order_id")
  createdAt  DateTime @default(now()) @map("created_at")

  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("license_keys")
}

model SiteConfig {
  id               String   @id @default(cuid())
  storeName        String   @default("Next E-commerce") @map("store_name")
  themeName        String   @default("modern") @map("theme_name")
  primaryColor     String   @default("#0f172a") @map("primary_color")
  secondaryColor   String   @default("#64748b") @map("secondary_color")
  fontFamily       String   @default("Inter, sans-serif") @map("font_family")
  borderRadius     String   @default("1.5rem") @map("border_radius")
  logoUrl          String?  @map("logo_url")
  bankName         String?  @map("bank_name")
  accountName      String?  @map("account_name")
  accountNumber    String?  @map("account_number")
  promptpayNumber  String?  @map("promptpay_number")
  qrCodeUrl        String?  @map("qr_code_url")
  faqContent       String   @default("ยังไม่มีข้อมูล FAQ") @map("faq_content")
  shippingContent  String   @default("ยังไม่มีข้อมูลนโยบายการจัดส่ง") @map("shipping_content")
  contactContent   String   @default("ยังไม่มีข้อมูลติดต่อเรา") @map("contact_content")
  facebookUrl      String?  @map("facebook_url")
  twitterUrl       String?  @map("twitter_url")
  instagramUrl     String?  @map("instagram_url")
  lineUrl          String?  @map("line_url")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model LiveStream {
  id                String    @id @default(cuid())
  title             String
  streamUrl         String?   @map("stream_url")
  status            String    @default("idle") // idle, live, ended
  featuredProductId String?   @map("featured_product_id")
  currentViewers    Int       @default(0) @map("current_viewers")
  startedAt         DateTime? @map("started_at")
  endedAt           DateTime? @map("ended_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  featuredProduct   Product?  @relation(fields: [featuredProductId], references: [id], onDelete: SetNull)

  @@map("live_streams")
}
